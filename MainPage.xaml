<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SoundPort.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SoundPort.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer>
        <Grid
            MaxWidth="760"
            Padding="40,32,40,40"
            RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="240" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource TitleLargeTextBlockStyle}"
                    Text="把电脑变成蓝牙音箱" />
                <TextBlock
                    MaxWidth="620"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="先在 Windows 蓝牙设置中配对安卓手机，然后在下方选择设备。连接后，手机播放的声音会从电脑当前音频输出播放。"
                    TextWrapping="Wrap" />
            </StackPanel>

            <InfoBar
                x:Name="StatusBar"
                Grid.Row="1"
                IsClosable="False"
                IsOpen="True"
                Message="正在搜索已配对的手机…"
                Severity="Informational"
                Title="正在准备" />

            <Grid Grid.Row="2" VerticalAlignment="Center">
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10">
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="可用设备" />
                    <ProgressRing
                        x:Name="SearchProgress"
                        Width="16"
                        Height="16"
                        IsIndeterminate="True"
                        Visibility="Collapsed" />
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="RefreshButton"
                        Click="RefreshButton_Click"
                        ToolTipService.ToolTip="重新扫描">
                        <SymbolIcon Symbol="Refresh" />
                    </Button>
                    <Button Click="OpenBluetoothSettings_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE8FD;" />
                            <TextBlock Text="打开蓝牙设置" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Border
                Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <ListView
                        x:Name="DeviceList"
                        Padding="4"
                        Background="Transparent"
                        ItemsSource="{x:Bind Receiver.Devices}"
                        SelectionChanged="DeviceList_SelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        VerticalAlignment="Center"
                                        FontSize="20"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE8EA;" />
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="2">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{Binding Name}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="蓝牙音频设备" />
                                    </StackPanel>
                                    <Border
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Padding="10,3"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="12"
                                        Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                            Text="已连接" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Grid x:Name="EmptyState" VerticalAlignment="Center">
                        <StackPanel
                            Margin="24"
                            HorizontalAlignment="Center"
                            Spacing="12">
                            <FontIcon
                                HorizontalAlignment="Center"
                                FontSize="32"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Glyph="&#xE8FD;" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="暂未发现可接收音频的已配对设备" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="请确认手机已与 Windows 配对，配对成功后会自动出现在这里。"
                                TextAlignment="Center" />
                            <Button
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                Click="OpenBluetoothSettings_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE8FD;" />
                                    <TextBlock Text="打开蓝牙设置" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel
                Grid.Row="4"
                Orientation="Horizontal"
                Spacing="12">
                <Button
                    x:Name="ConnectButton"
                    Click="ConnectButton_Click"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Play" />
                        <TextBlock Text="连接" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="DisconnectButton"
                    Click="DisconnectButton_Click"
                    IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Stop" />
                        <TextBlock Text="断开" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
