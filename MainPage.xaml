<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SoundPort.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid MaxWidth="820" Padding="40,32,40,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="8">
                <TextBlock
                    FontSize="32"
                    FontWeight="SemiBold"
                    Text="把电脑变成蓝牙音箱" />
                <TextBlock
                    MaxWidth="650"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="先在 Windows 蓝牙设置中配对安卓手机，然后在下方选择设备。连接后，手机播放的声音会从电脑当前音频输出播放。"
                    TextWrapping="Wrap" />
            </StackPanel>

            <InfoBar
                x:Name="StatusBar"
                Grid.Row="1"
                Margin="0,24,0,0"
                IsClosable="False"
                IsOpen="True"
                Message="正在搜索已配对的手机…"
                Severity="Informational"
                Title="正在准备" />

            <Grid Grid.Row="2" Margin="0,28,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="可用设备" />
                <Button Grid.Column="1" Click="OpenBluetoothSettings_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Setting" />
                        <TextBlock Text="打开蓝牙设置" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="3" MinHeight="190">
                <ListView
                    x:Name="DeviceList"
                    ItemsSource="{x:Bind Receiver.Devices}"
                    SelectionChanged="DeviceList_SelectionChanged"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    FontSize="22"
                                    Glyph="&#xE702;" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="蓝牙音频设备" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Grid
                    x:Name="EmptyState"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    IsHitTestVisible="False">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon FontSize="24" Glyph="&#xE702;" />
                        <TextBlock Text="暂未发现可接收音频的已配对设备" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="请确认手机已与 Windows 配对，然后稍候。"
                            TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>

            <CommandBar
                Grid.Row="4"
                Margin="0,20,0,0"
                Background="Transparent"
                DefaultLabelPosition="Right">
                <AppBarButton
                    x:Name="ConnectButton"
                    Click="ConnectButton_Click"
                    Icon="Play"
                    IsEnabled="False"
                    Label="连接" />
                <AppBarButton
                    x:Name="DisconnectButton"
                    Click="DisconnectButton_Click"
                    Icon="Stop"
                    IsEnabled="False"
                    Label="断开" />
                <CommandBar.SecondaryCommands>
                    <AppBarButton
                        Click="RefreshButton_Click"
                        Icon="Refresh"
                        Label="重新扫描" />
                </CommandBar.SecondaryCommands>
            </CommandBar>
        </Grid>
    </ScrollViewer>
</Page>
